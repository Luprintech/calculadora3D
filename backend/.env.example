# ── FilamentOS Backend — Variables de entorno ────────────────────────────────
# Copia este archivo como .env y rellena los valores reales.
# NUNCA commitees .env al repositorio.
#
# IMPORTANTE: Si alguna vez el .env real fue expuesto en git o en logs,
# rota inmediatamente los secretos afectados en:
#   - Google Cloud Console (OAuth client secret)
#   - Google AI Studio (API Key GOOGLE_GENAI_API_KEY)

# ── Puerto del servidor Express ───────────────────────────────────────────────
PORT=3001

# ── Origen del frontend (CORS) ────────────────────────────────────────────────
CLIENT_ORIGIN=http://localhost:9002

# ── Base de datos SQLite ──────────────────────────────────────────────────────
# Ruta absoluta o relativa al archivo .db. Vacío = usa data.db en raíz del proyecto.
DB_PATH=

# ── Sesiones Express ─────────────────────────────────────────────────────────
# Usa un secreto aleatorio largo y único por entorno. Ejemplo de generación:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=CAMBIA_ESTE_VALOR_POR_UN_SECRETO_ALEATORIO_LARGO

# ── Google OAuth 2.0 ──────────────────────────────────────────────────────────
# Obtén las credenciales en: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Google Generative AI (Gemini) ─────────────────────────────────────────────
# Obtén la API key en: https://aistudio.google.com/apikey
GOOGLE_GENAI_API_KEY=your-google-genai-api-key

# ── Entorno ───────────────────────────────────────────────────────────────────
NODE_ENV=development

# ── Puppeteer (opcional) ──────────────────────────────────────────────────────
# Si usas un Chromium custom (p.ej. en Docker), especifica la ruta aquí.
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser

# ── SMTP (reporte de bugs) ────────────────────────────────────────────────────
# Configura tu servidor SMTP para enviar reportes de bugs.
# Gmail: smtp.gmail.com:587 (requiere contraseña de aplicación)
# Outlook: smtp-mail.outlook.com:587
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu-email@gmail.com
SMTP_PASS=tu-contraseña-de-aplicacion-de-16-caracteres
# Email destino para recibir los reportes
BUG_REPORT_EMAIL=soporte@tu-empresa.com
